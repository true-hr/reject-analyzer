{
  "manifest_version": 3,
  "name": "PASSMAP AI \uc791\uc5c5 \uc800\uc7a5",
  "version": "0.1.7",
  "description": "ChatGPT strict \ucea1\ucc98\ub85c \ud604\uc7ac \ub300\ud654 \ub610\ub294 \uc120\ud0dd\ud55c \ud14d\uc2a4\ud2b8\ub97c PASSMAP AI \ub300\ud654 \ud0ed\uc73c\ub85c \ubcf4\ub0c5\ub2c8\ub2e4.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://passmap-app.vercel.app/*",
    "https://reject-analyzer.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://passmap-app.vercel.app/*",
        "https://reject-analyzer.vercel.app/*"
      ],
      "js": [
        "content-passmap.js"
      ],
      "run_at": "document_start"
    }
  ]
}
