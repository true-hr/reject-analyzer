{
  "manifest_version": 3,
  "name": "PASSMAP \uc120\ud0dd \ud14d\uc2a4\ud2b8 \ubcf4\ub0b4\uae30",
  "version": "0.1.2",
  "description": "ChatGPT/Gemini/Claude 등 어떤 웹페이지에서든 사용자가 선택한 텍스트를 PASSMAP의 AI 대화 탭으로 보냅니다. 전체 대화를 자동 수집하지 않습니다.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://passmap-app.vercel.app/*",
    "https://reject-analyzer.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://passmap-app.vercel.app/*",
        "https://reject-analyzer.vercel.app/*"
      ],
      "js": [
        "content-passmap.js"
      ],
      "run_at": "document_start"
    }
  ]
}
