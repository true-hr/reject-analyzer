                            <div className={`mt-3 space-y-3 hidden data-[open-${sectionKey}='1']:block`}>
                              {itemsMore.map((h, i) => (
                                <HypothesisCard key={h?.id || `${sectionKey}_more_${i}`} h={h} />
                              ))}
                            </div>
                          ) : null}
