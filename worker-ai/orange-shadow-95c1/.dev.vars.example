# PASSMAP Cloudflare Worker 로컬 개발용 환경변수 예시
# 이 파일을 .dev.vars로 복사하고 실제 값을 입력하세요.
# .dev.vars는 절대 git에 커밋하지 마세요.
#
# 운영 환경에서는 이 파일을 사용하지 않습니다.
# 운영 secret은 반드시 Cloudflare Dashboard > Workers > Settings > Variables (Secret)
# 또는 `wrangler secret put <NAME>` 명령으로 등록하세요.

# ── AI API ──────────────────────────────────────────────────────
# [SECRET] Gemini API key (v1). GEMINI_API_KEY_V2가 있으면 V2 우선 사용.
GEMINI_API_KEY=

# [SECRET] Gemini API key (v2, 우선 사용). 없으면 V1으로 fallback.
GEMINI_API_KEY_V2=

# ── Supabase ────────────────────────────────────────────────────
# Supabase 프로젝트 URL (semi-public, 하지만 Worker 전용으로 관리)
# 예: https://your-project-id.supabase.co
SUPABASE_URL=

# [SECRET] Supabase service role key — RLS 우회 admin 권한.
# 절대 프론트엔드(VITE_ prefix)에 노출하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=

# ── Notion OAuth ────────────────────────────────────────────────
# Notion OAuth 앱 Client ID (semi-public, OAuth URL에 포함됨)
NOTION_CLIENT_ID=

# [SECRET] Notion OAuth 앱 Client Secret.
# 절대 클라이언트/로그에 노출하지 마세요.
NOTION_CLIENT_SECRET=

# Notion OAuth redirect URI. Worker 배포 URL과 정확히 일치해야 합니다.
# Notion integrations 페이지 설정값과 동일하게 유지하세요.
# 예: https://reject-ai-proxy.your-account.workers.dev/api/notion/callback
NOTION_REDIRECT_URI=

# ── Token Encryption ────────────────────────────────────────────
# [SECRET] Notion access_token AES-256-GCM 암호화 키 (32바이트 base64).
# 생성: openssl rand -base64 32
# 변경 시 기존 모든 Notion 연결 토큰을 복호화할 수 없게 됩니다.
TOKEN_ENCRYPTION_KEY=
