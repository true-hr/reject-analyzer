# PASSMAP Frontend 환경변수 예시
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# .env.local은 절대 git에 커밋하지 마세요.

# Supabase project settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Worker base URL (Notion import, AI parse/enhance 공통 사용)
# 예: https://reject-ai-proxy.your-account.workers.dev
VITE_AI_PROXY_URL=

# Worker URL fallback (VITE_AI_PROXY_URL 미설정 시 사용)
VITE_API_BASE=

# /api/parse 전용 base URL override (미설정 시 VITE_AI_PROXY_URL로 fallback)
VITE_PARSE_API_BASE=

# Google Calendar 자동연동 UI shell 노출 여부 (CAL-4B)
# 기본값: false — 실제 사용자 화면에 노출하지 않음
# OAuth/API/DB 구현(CAL-5 이후) 전까지 true로 배포하지 마세요.
# 이 flag는 보안 장치가 아니라 UI 표시 제어용입니다.
VITE_GOOGLE_CALENDAR_ENABLED=false
